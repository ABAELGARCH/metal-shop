generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin Users ─────────────────────────────────────────

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

// ─── Products ────────────────────────────────────────────

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?
  price       Int     // cents
  compareAtPrice Int? @map("compare_at_price")
  published   Boolean @default(false)
  featured    Boolean @default(false)
  sortOrder   Int     @default(0) @map("sort_order")

  // JSON: { zones: [{ id, x, y, maxWidth, maxChars, font, fontSize, color, defaultText }] }
  customizationConfig Json @map("customization_config")

  dxfTemplateId      Int?         @map("dxf_template_id")
  dxfTemplate        DxfTemplate? @relation(fields: [dxfTemplateId], references: [id])

  teelaunchProductId String? @map("teelaunch_product_id")
  teelaunchVariantId String? @map("teelaunch_variant_id")

  categoryId Int?      @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images     ProductImage[]
  orderItems OrderItem[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  url       String
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isBase    Boolean @default(false) @map("is_base")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  products  Product[]

  @@map("categories")
}

// ─── DXF Templates ───────────────────────────────────────

model DxfTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  dxfFilePath String   @map("dxf_file_path")
  // JSON: { zones: [{ id, insertX, insertY, layerName, style, height }] }
  zoneConfig  Json     @map("zone_config")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("dxf_templates")
}

// ─── Orders ──────────────────────────────────────────────

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique @map("order_number")
  status      OrderStatus @default(PENDING_PAYMENT)

  customerEmail String  @map("customer_email")
  customerName  String  @map("customer_name")
  customerPhone String? @map("customer_phone")

  shippingName    String  @map("shipping_name")
  shippingLine1   String  @map("shipping_line1")
  shippingLine2   String? @map("shipping_line2")
  shippingCity    String  @map("shipping_city")
  shippingState   String  @map("shipping_state")
  shippingZip     String  @map("shipping_zip")
  shippingCountry String  @default("US") @map("shipping_country")

  subtotal     Int @default(0)
  shippingCost Int @default(0) @map("shipping_cost")
  tax          Int @default(0)
  total        Int

  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id")
  stripePaidAt          DateTime? @map("stripe_paid_at")

  teelaunchOrderId     String?   @unique @map("teelaunch_order_id")
  teelaunchSubmittedAt DateTime? @map("teelaunch_submitted_at")
  teelaunchStatus      String?   @map("teelaunch_status")

  trackingNumber  String?   @map("tracking_number")
  trackingCarrier String?   @map("tracking_carrier")
  trackingUrl     String?   @map("tracking_url")
  shippedAt       DateTime? @map("shipped_at")

  generatedDxfPath String? @map("generated_dxf_path")
  generatedPngPath String? @map("generated_png_path")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items         OrderItem[]
  statusHistory OrderStatusEvent[]

  @@map("orders")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  PAID
  PROCESSING
  FILE_GENERATED
  SUBMITTED_TO_PRINT
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int    @map("order_id")
  productId   Int    @map("product_id")
  productName String @map("product_name")
  productSlug String @map("product_slug")
  quantity    Int    @default(1)
  unitPrice   Int    @map("unit_price")

  // JSON: { zones: [{ id, text }] }
  customizationData Json @map("customization_data")
  previewImageUrl   String? @map("preview_image_url")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderStatusEvent {
  id        Int         @id @default(autoincrement())
  orderId   Int         @map("order_id")
  status    OrderStatus
  note      String?
  createdBy String?     @map("created_by")
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_events")
}

// ─── Settings ────────────────────────────────────────────

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}
